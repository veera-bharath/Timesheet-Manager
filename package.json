{
  "name": "timesheet-manager",
  "version": "2.1.0",
  "description": "Weekly Jira & Service Desk Time Tracking Application",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "pack": "electron-vite build && electron-builder --dir",
    "dist": "electron-vite build && electron-builder"
  },
  "keywords": [
    "timesheet",
    "tracker"
  ],
  "author": "Developer",
  "license": "ISC",
  "build": {
    "appId": "com.timesheet.manager",
    "productName": "Timesheet Manager",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**",
      "favicon.png"
    ],
    "win": {
      "target": "nsis",
      "icon": "favicon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "publish": {
      "provider": "github",
      "owner": "veera-bharath",
      "repo": "Timesheet-Manager"
    }
  },
  "devDependencies": {
    "electron": "^41.0.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "vite-plugin-static-copy": "^4.0.0"
  },
  "dependencies": {
    "electron-store": "^8.2.0",
    "electron-updater": "^6.8.3"
  }
}
